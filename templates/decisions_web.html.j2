<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} — reasonable-ux</title>
<style>
  :root {
    --bg: #0a0a0b;
    --bg-elev: #111114;
    --surface-2: #16161b;
    --fg: #e8e8ea;
    --muted: #8a8a93;
    --border: #232327;
    --accent: #c77dff;
    --accent-hover: #d69bff;
    --code-bg: #0d1117;
    --font-sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    --measure: 68ch;
    --content-max: 760px;
    --lh-body: 1.6;
    --lh-display: 1.15;
  }
  @media (prefers-color-scheme: light) {
    :root {
      --bg: #fafafb;
      --bg-elev: #ffffff;
      --surface-2: #f4f4f6;
      --fg: #111113;
      --muted: #555560;
      --border: #e1e1e6;
      --accent: #7b2cbf;
      --accent-hover: #5a1e94;
      --code-bg: #f6f8fa;
    }
  }
  * { box-sizing: border-box; }
  html { color-scheme: dark light; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: var(--lh-body);
    -webkit-font-smoothing: antialiased;
  }
  .container {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: 4rem clamp(1rem, 5vw, 2rem) 6rem;
  }
  header.doc-head {
    border-bottom: 1px solid var(--border);
    padding-bottom: 2rem;
    margin-bottom: 2.5rem;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }
  .eyebrow .accent { color: var(--accent); }
  h1 {
    font-size: clamp(1.75rem, 1.43rem + 1.64vw, 2.5rem);
    font-weight: 600;
    line-height: var(--lh-display);
    letter-spacing: -0.015em;
    margin: 0;
    text-wrap: balance;
  }
  h2 {
    font-size: clamp(1.375rem, 1.2rem + 0.9vw, 1.75rem);
    font-weight: 600;
    line-height: var(--lh-display);
    letter-spacing: -0.015em;
    margin: 4rem 0 1rem;
    text-wrap: balance;
  }
  h2 .num {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    margin-right: 0.4em;
  }
  h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 2.5rem 0 0.75rem;
    color: var(--fg);
  }
  p { margin: 0 0 1rem; max-width: var(--measure); }
  .intro p { color: var(--muted); }
  .section-intro p { color: var(--muted); }
  .field {
    margin: 0.75rem 0;
    max-width: var(--measure);
  }
  .field-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-right: 0.5em;
  }
  .field-content { color: var(--fg); }
  code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--code-bg);
    padding: 0.15em 0.35em;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  code.code-ref, .code-ref {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--accent);
  }
  hr.decision-sep {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
  strong { font-weight: 600; color: var(--fg); }
  em { font-style: italic; }
  a {
    color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.15em;
  }
  a:hover { color: var(--accent-hover); }
  footer.doc-foot {
    margin-top: 5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--muted);
  }
  footer.doc-foot a { color: var(--muted); }
  footer.doc-foot a:hover { color: var(--fg); }
</style>
</head>
<body>
<div class="container">

<header class="doc-head">
  <p class="eyebrow">reasonable-ux <span class="accent">·</span> decisions log</p>
  <h1>{{ title }}</h1>
</header>

{% if intro %}
<section class="intro">
  <p>{{ intro | safe }}</p>
</section>
{% endif %}

{% for sec in sections %}
<section>
  <h2>{% if sec.num %}<span class="num">{{ sec.num }}.</span>{% endif %}{{ sec.title }}</h2>
  {% if sec.intro %}
  <div class="section-intro">
    <p>{{ sec.intro | safe }}</p>
  </div>
  {% endif %}
  {% for dec in sec.decisions %}
  <article class="decision">
    <h3>{{ dec.title }}</h3>
    {% for f in dec.fields %}
    <p class="field">
      <span class="field-label">{{ f.label }}</span>
      <span class="field-content">{{ f.content | safe }}</span>
    </p>
    {% endfor %}
    {% if not loop.last %}<hr class="decision-sep">{% endif %}
  </article>
  {% endfor %}
</section>
{% endfor %}

<footer class="doc-foot">
  <p>Source: <code>DECISIONS.md</code> · Rendered with <code>render_decisions.py</code> · <a href="DECISIONS.pdf">PDF version</a></p>
</footer>

</div>
</body>
</html>
