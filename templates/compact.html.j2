{#
  compact.html.j2 — 5-page compact UX evaluation report.
  Rendered by generate_report._render_jinja. The normalizer (report_data.load)
  produces the context: site, personas, steps, metrics, themes,
  recommendations, severityMeta, meta.
#}
{% set theme = theme | default("editorial") %}
{% set body_class = {"editorial": "ed-body", "technical": "tk-body", "studio": "st-body"}[theme] %}
<!doctype html>
<html lang="en" data-aesthetic="{{ theme }}">
<head>
  <meta charset="utf-8">
  <title>Compact UX Evaluation — {{ site.name }}</title>
  <link rel="stylesheet" href="styles/tokens.css">
  <link rel="stylesheet" href="styles/page.css">
  <link rel="stylesheet" href="styles/{{ theme }}.css">
</head>
<body>
<div class="{{ body_class }}" data-aesthetic="{{ theme }}">

  {#— Page 1 · Cover + exec summary collapsed —#}
  <section class="page cover" style="height: 11in; padding: 0.75in 0.75in 0.6in;">
    <div style="
        height: 100%;
        display: grid; grid-template-rows: auto 1fr auto;
        gap: 0;">
      <div style="display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid var(--rule); padding-bottom: 8px;">
        <span class="small-caps">ReasonableUX · Compact Report</span>
        <span class="small-caps">{{ meta.date }}</span>
      </div>

      <div style="align-self: center; margin-top: 24px;">
        <div class="eyebrow">Multi-persona UX evaluation</div>
        <h1 style="margin: 10px 0 0; font-size: 44pt; line-height: 1.02; letter-spacing: -0.03em;">
          {{ site.name }}<span style="color: var(--accent);">.</span>
        </h1>
        <div style="
            margin-top: 14px;
            font-family: var(--font-display);
            font-style: italic;
            font-size: 13pt;
            color: var(--muted);
            max-width: 42ch;
            line-height: 1.3;">
          {{ metrics.personasCount }}-persona evaluation across {{ metrics.stepsCount }} steps — the five-minute read.
        </div>

        <div class="grid g-4 gap-3 mt-6">
          {% with label="Overall", value=metrics.overall, sub="/ 5" %}{% include "partials/summary_stat.html" %}{% endwith %}
          {% with label="Personas", value=metrics.personasCount, sub=None %}{% include "partials/summary_stat.html" %}{% endwith %}
          {% with label="Friction pts", value=metrics.totalFriction, sub=None %}{% include "partials/summary_stat.html" %}{% endwith %}
          {% with label="Recommendations", value=metrics.totalRecs, sub=None %}{% include "partials/summary_stat.html" %}{% endwith %}
        </div>

        {% if themes %}
        <div class="mt-6" style="
            border-left: 3px solid var(--accent);
            padding-left: 14px;
            font-size: 11pt; line-height: 1.5;
            max-width: 62ch;">
          <strong>The take:</strong> {{ metrics.stepsCount }}-step walkthrough surfaced
          {{ metrics.totalFriction }} friction points and {{ metrics.totalRecs }} recommendations.
          {% if themes | length >= 1 %}
          Recurring problems: {{ themes[:3] | map(attribute='label') | map('lower') | join('; ') }}.
          {% endif %}
        </div>
        {% endif %}
      </div>

      <div style="display: flex; justify-content: space-between; align-items: end; border-top: 1px solid var(--rule); padding-top: 10px;">
        <div style="display: flex;">
          {% for p in personas %}
          <div style="margin-left: {% if loop.first %}0{% else %}-8px{% endif %};">
            {% with persona=p, size=36 %}{% include "partials/persona_avatar.html" %}{% endwith %}
          </div>
          {% endfor %}
        </div>
        <div style="text-align: right;">
          <div class="caption">Prepared by</div>
          <div style="font-family: var(--font-display); font-size: 12pt; font-weight: 500;">{{ meta.evaluator }}</div>
        </div>
      </div>
    </div>
  </section>

  {#— Page 2 · Personas + scores + severity + themes —#}
  <section class="page" style="height: 11in;">
    <header class="page-head">
      <span class="small-caps text-muted">Personas · scores</span>
      <span class="small-caps text-muted">{{ site.name }}</span>
    </header>
    <div class="page-body">
      <div class="eyebrow mb-1">Who we sent in</div>
      <h2 style="margin: 0 0 12px;">{{ personas | length }} personas, {{ steps | length }} steps</h2>
      {% set pcols = [personas | length, 3] | min %}
      <div class="grid gap-3" style="grid-template-columns: repeat({{ pcols }}, 1fr);">
        {% for p in personas %}
          {% with persona=p %}{% include "partials/persona_card_standard.html" %}{% endwith %}
        {% endfor %}
      </div>

      <hr class="rule mt-4">

      <div class="grid gap-4 mt-3" style="grid-template-columns: 1fr 1fr;">
        <div>
          <div class="eyebrow mb-2">Subscores</div>
          <div style="display: flex; flex-direction: column; gap: 8px;">
            {% with label="CTA clarity", value=metrics.avgScores.cta %}{% include "partials/score_bar.html" %}{% endwith %}
            {% with label="Copy quality", value=metrics.avgScores['copy'] %}{% include "partials/score_bar.html" %}{% endwith %}
            {% with label="Flow smoothness", value=metrics.avgScores.flow %}{% include "partials/score_bar.html" %}{% endwith %}
          </div>
        </div>
        <div>
          <div class="eyebrow mb-2">Friction by severity</div>
          {% with counts=metrics.frictionBySeverity %}{% include "partials/severity_bar.html" %}{% endwith %}
          <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px;">
            {% for m in severityMeta %}
            {% if metrics.frictionBySeverity[loop.index0] > 0 %}
            <span class="caption" style="display: inline-flex; align-items: center;">
              <span class="sev-glyph sev-{{ loop.index0 }}"></span>{{ metrics.frictionBySeverity[loop.index0] }} {{ m.label | lower }}
            </span>
            {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      {% if themes %}
      <hr class="rule mt-4">
      <div class="eyebrow mt-3 mb-2">Friction themes, ranked</div>
      {% include "partials/themes_list.html" %}
      {% endif %}
    </div>
    <footer class="page-foot">
      <span class="folio">02 · Personas &amp; scores</span>
      <span class="folio">Compact report</span>
    </footer>
  </section>

  {#— Page 3 · Walkthrough strip —#}
  <section class="page" style="height: 11in;">
    <header class="page-head">
      <span class="small-caps text-muted">Walkthrough</span>
      <span class="small-caps text-muted">{{ site.name }}</span>
    </header>
    <div class="page-body">
      <div class="eyebrow mb-1">The journey</div>
      <h2 style="margin: 0 0 12px;">Where each persona got stuck</h2>
      {% set _persona_by_id = {} %}
      {% for p in personas %}{% set _ = _persona_by_id.update({p.id: p}) %}{% endfor %}
      <div style="display: flex; flex-direction: column; gap: 10px;">
        {% for s in steps %}
        {% set p = _persona_by_id.get(s.personaId) or personas[0] %}
        {% with step=s, persona=p, severityMeta=severityMeta %}{% include "partials/compact_step_row.html" %}{% endwith %}
        {% endfor %}
      </div>
    </div>
    <footer class="page-foot">
      <span class="folio">03 · Walkthrough</span>
      <span class="folio">{{ steps | length }} steps</span>
    </footer>
  </section>

  {#— Page 4 · Cross-persona matrix —#}
  <section class="page" style="height: 11in;">
    <header class="page-head">
      <span class="small-caps text-muted">Cross-persona matrix</span>
      <span class="small-caps text-muted">{{ site.name }}</span>
    </header>
    <div class="page-body">
      <div class="eyebrow mb-1">Every friction, every persona</div>
      <h2 style="margin: 0 0 12px;">The full matrix, one screen</h2>
      {% include "partials/persona_matrix.html" %}
    </div>
    <footer class="page-foot">
      <span class="folio">04 · Matrix</span>
      <span class="folio">Issue × persona</span>
    </footer>
  </section>

  {#— Page 5 · Recommendations grid —#}
  <section class="page" style="height: 11in;">
    <header class="page-head">
      <span class="small-caps text-muted">Recommendations</span>
      <span class="small-caps text-muted">{{ site.name }}</span>
    </header>
    <div class="page-body">
      <div class="eyebrow mb-1">What to do</div>
      <h2 style="margin: 0 0 6px;">Prioritized fixes</h2>
      <p class="caption mb-4" style="max-width: 70ch;">
        Start top-left. Everything in the quick-wins quadrant ships in a sprint.
      </p>
      {% include "partials/recommendation_grid.html" %}
    </div>
    <footer class="page-foot">
      <span class="folio">05 · Recommendations</span>
      <span class="folio">Impact × effort</span>
    </footer>
  </section>

</div>
</body>
</html>
