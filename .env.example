# Required for default provider (anthropic)
ANTHROPIC_API_KEY=

# Optional — only needed if you pass --provider openai or --provider google
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional — Langfuse tracing (disabled if unset; get keys at cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=              # defaults to https://cloud.langfuse.com

# Optional — set to "true" to force headless browser (auto-detected from CI env otherwise)
# CI=false
