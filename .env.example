# Required for default provider (anthropic)
ANTHROPIC_API_KEY=

# Optional — only needed if you pass --provider openai or --provider google
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional — Langfuse tracing via LiteLLM langfuse_otel callback (disabled if unset)
# Get keys at cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_OTEL_HOST=         # defaults to https://us.cloud.langfuse.com (set to https://cloud.langfuse.com for EU)

# Optional — set to "true" to force headless browser (auto-detected from CI env otherwise)
# CI=false
